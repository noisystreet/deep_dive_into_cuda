flowchart TB
    subgraph compile["编译期 (-gencode × N)"]
        G75["-gencode arch=compute_75,code=sm_75<br/>→ compute_75.cubin (3.2 KB)"]
        G89["-gencode arch=compute_89,code=sm_89<br/>→ compute_89.cubin (3.5 KB)"]
        PTX["-gencode arch=compute_89,code=compute_89<br/>→ compute_89.ptx (1.3 KB)"]
        FB["fatbinary --create<br/>合并为 vector_add.fatbin"]
        G75 --> FB
        G89 --> FB
        PTX --> FB
    end

